GROQ_API_KEY=your_groq_api_key_here
WANDB_API_KEY=your_wandb_api_key_here
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# Supabase — Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Supabase — Project Settings → Database → Connection string (Transaction pooler, port 6543)
# Use the transaction pooler URL for FastAPI (async, short-lived connections)
# Use the session pooler (port 5432) or direct connection for PostgresSaver
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL_SESSION=postgresql://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Upstash Redis — console.upstash.com → your database → REST API
UPSTASH_REDIS_URL=https://your-endpoint.upstash.io
UPSTASH_REDIS_TOKEN=your_upstash_token_here
